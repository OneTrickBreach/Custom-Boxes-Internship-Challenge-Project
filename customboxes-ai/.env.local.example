# ---- Claude API (required for "real" mode) ----
# Get one at https://console.anthropic.com/settings/keys and add credits at
# https://console.anthropic.com/settings/billing ($5 is plenty for demo).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- Demo / simulation mode ----
# Set DEMO_MODE=true to force canned responses even if an API key is set.
# If ANTHROPIC_API_KEY is blank, demo mode auto-activates (no key, no cost).
# A small "Demo Mode" pill shows in the header so it's clear the responses
# are simulated. Unset this and restart the dev server to go live.
# DEMO_MODE=true
